{
    "name": "alexisgt01/cms-core",
    "description": "Headless CMS core package with Filament admin panel",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "spatie/laravel-permission": "^7.2.1",
        "spatie/laravel-medialibrary": "^11.21",
        "spatie/laravel-model-states": "^2.13",
        "spatie/laravel-sitemap": "^7.4",
        "spatie/laravel-activitylog": "^4.12"
    },
    "suggest": {
        "owenvoke/blade-fontawesome": "Font Awesome icons for the Icon Picker (^2.0)",
        "codeat3/blade-simple-icons": "Brand/company icons (Netflix, Docker, Laravel, etc.) for the Icon Picker (^5.0)"
    },
    "autoload": {
        "psr-4": {
            "Alexisgt01\\CmsCore\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Alexisgt01\\CmsCore\\CmsCoreServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
